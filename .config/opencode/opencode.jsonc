{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "careful",
  "agent": {
    "general": {
      "model": "openai/gpt-5.3-codex",
    },
  },
  "mcp": {
    "paper": {
      "type": "remote",
      "url": "http://127.0.0.1:29979/mcp",
      "enabled": true,
    },
  },
  "experimental": {
    "disable_paste_summary": true,
  },
  // "plugin": ["opencode-anthropic-auth"]
}
